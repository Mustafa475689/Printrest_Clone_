<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profileUser.username %> Profile</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .post-card {
      cursor: pointer;
      transition: 0.3s;
    }

    .post-card:hover {
      transform: scale(1.03);
    }

    .card-img-top {
  max-height: 350px;
  object-fit: cover;
}   
    .profile-pic {
      object-fit: cover;
       transform: scale(1.1);
    }
  </style>
</head>

<body class="bg-light">
<!-- Navbar -->
  <nav class="navbar navbar-light bg-white shadow-sm px-4">

    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Pinterest-logo.png" width="30" height="30">

      <span class="fw-bold text-danger">Printrest</span>
    </a>

    <!-- Search Bar and feed -->
    <div class="d-flex align-items-center gap-3 flex-grow-1 mx-4">

      <a href="/" class="text-danger fw-bold text-decoration-none">
        Feed
      </a>

      <form action="/search" method="GET" class="flex-grow-1">
        <input type="text" name="query" class="form-control rounded-pill" placeholder="Search for ideas...">
      </form>

    </div>
    <!-- end  -->

    <!-- Buttons -->
    <% if(currentUser){ %>

  <div class="d-flex align-items-center gap-3">

    <a href="/profile">
      <img
        src="<%= currentUser?.dp || 'https://via.placeholder.com/40' %>"
        class="profile-pic rounded-circle border"
        width="40"
        height="40"
        style="object-fit: cover">
    </a>

    <a href="/logout" class="btn btn-outline-danger btn-sm">
      Logout
    </a>

  </div>

<% } else { %>

  <div class="d-flex gap-2">

    <a href="/login" class="btn btn-danger btn-sm">
      Login
    </a>

    <a href="/register" class="btn btn-outline-danger btn-sm">
      Signup
    </a>

  </div>

        <% } %>

  </nav>
<!--  ss-->

<div class="container mt-4">

  <!-- User Info -->
  <div class="card shadow-sm mb-4">
    <div class="card-body text-center">

      <img src="<%= profileUser.dp %>"
           class="rounded-circle border profile-pic"
           width="120"
           height="120">

      <h3 class="mt-3 mb-1">
        <%= profileUser.fullname %>
      </h3>

      <p class="text-muted mb-1">
        @<%= profileUser.username %>
      </p>

      <% if(profileUser.email){ %>
        <p class="text-muted">
          <%= profileUser.email %>
        </p>
      <% } %>

      <p>
        <strong><%= profileUser.posts.length %></strong> Posts
      </p>

    </div>
  </div>

  <!-- Posts -->
  <h4 class="mb-3">
    Posts
  </h4>

  <% if(profileUser.posts.length > 0){ %>

    <div class="row">

      <% profileUser.posts.forEach(function(post){ %>

          <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

            <div class="card border-0 shadow-sm post-card">

              <img src="<%= post.image %>"
                   class="card-img-top">

              <div class="card-body">

                <h6 class="fw-bold">
                  <%= post.title %>
                </h6>

                <p class="text-muted small">
                  <%= post.description %>
                </p>

                <!-- Like + Save -->
<div class="d-flex align-items-center gap-2">

  <!-- LIKE -->
  <form action="/like/<%= post._id %>" method="POST" class="m-0">

    <% if(post.liked){ %>

      <button class="btn btn-sm btn-outline-danger">
        ❤️ Like
      </button>

    <% } else { %>

      <button class="btn btn-sm btn-outline-secondary">
        🤍 Like
      </button>

    <% } %>

  </form>

  <!-- LIKE COUNT -->
  <small class="text-muted">
    <%= post.likeCount || 0 %> likes
  </small>

  <!-- SAVE -->
  <form action="/save/<%= post._id %>" method="POST" class="m-0 ms-auto">

  <% let isSaved = currentUser?.savedPosts?.some(
  id => id.toString() === post._id.toString()
) || false; %>

    <% if(isSaved){ %>

      <button class="btn btn-sm btn-warning">
        ⭐ Saved
      </button>

    <% } else { %>

      <button class="btn btn-sm btn-outline-warning">
        ☆ Save
      </button>

    <% } %>

  </form>

  <!-- SAVE COUNT -->
  <small class="text-muted ms-2">
    <%= post.saveCount || 0 %> saves
  </small>

</div>
                <!-- End of like and save buttons -->

              </div>

            </div>

          </div>

        <% }) %>

      </div>

    <% } else { %>

      <div class="alert alert-secondary">
        No posts yet.
      </div>

    <% } %>

  </div>

</body>
</html>