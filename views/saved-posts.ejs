<!DOCTYPE html>
<html>
<head>
  <title>Saved Posts</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    
  <!-- NAVBAR -->
<nav class="navbar navbar-light bg-white shadow-sm px-4">

  <!-- Logo -->
  <a class="navbar-brand d-flex align-items-center gap-2" href="/">
    <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Pinterest-logo.png"
         width="30"
         height="30">

    <span class="fw-bold text-danger">Printrest</span>
  </a>

  <!-- Feed + Search -->
  <div class="d-flex align-items-center gap-3 flex-grow-1 mx-4">

    <a href="/"
       class="text-danger fw-bold text-decoration-none">
      Feed
    </a>

    <form action="/search" method="GET" class="flex-grow-1">
      <input
        type="text"
        name="query"
        class="form-control rounded-pill"
        placeholder="Search for ideas..."
      >
    </form>

  </div>

  <!-- Right Side -->
  <div class="d-flex align-items-center gap-3">

    <!-- Profile Link -->
    <a href="/profile"
       class="text-dark fw-bold text-decoration-none profile-pic">
    </a>

    <!-- DP -->
    <a href="/profile">
      <img
        src="/images/uploads/<%= user.dp %>"
        class="profile-pic rounded-circle border"
        width="40"
        height="40"
        style="object-fit: cover;"
      >
    </a>

    <!-- Logout -->
    <a href="/logout"
       class="btn btn-outline-danger btn-sm">
      Logout
    </a>

  </div>

</nav>
<!-- end of navbar -->

<div class="container mt-4">

  <div class="d-flex justify-content-between mb-4">

    <h2>⭐  Saved Posts</h2>

  </div>

  <% if(user.savedPosts.length > 0){ %>

    <div class="row">

      <% user.savedPosts.forEach(function(post){ %>

        <div class="col-md-4 mb-4">

          <div class="card shadow-sm">

            <a href="/post/<%= post._id %>">
              <img
                src="/images/uploads/<%= post.image %>"
                class="card-img-top">
            </a>

            <div class="card-body">

              <h6><%= post.title %></h6>

              <p class="text-muted">
                <%= post.description %>
              </p>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

  <% } else { %>

    <div class="alert alert-secondary">
      No saved posts yet 📌
    </div>

  <% } %>

</div>

</body>
</html>