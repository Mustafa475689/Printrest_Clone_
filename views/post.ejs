<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= post.title %> - Printrest
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <!-- Navbar -->
  <nav class="navbar navbar-light bg-white shadow-sm px-4">

    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Pinterest-logo.png" width="30" height="30">

      <span class="fw-bold text-danger">
        Printrest
      </span>
    </a>

    <a href="/" class="btn btn-outline-danger btn-sm">
      Back to Feed
    </a>

  </nav>

  <!-- Post Container -->
  <div class="container mt-5">

    <div class="card border-0 shadow-lg">

      <div class="row g-0">

        <!-- Left Side Image -->
        <div class="col-md-7">

          <img src="<%= post.image %>" class="img-fluid w-100" alt="<%= post.title %>">

        </div>

        <!-- Right Side Details -->
        <div class="col-md-5">

          <div class="card-body p-4">

            <h2 class="fw-bold">
              <%= post.title %>
            </h2>

            <p class="text-muted mt-3">
              <%= post.description %>
            </p>

            <hr>

            <h6 class="fw-bold">
              Posted By
            </h6>

            <div class="d-flex align-items-center gap-3 mb-3">

              <a href="/user/<%= post.user._id %>">
                <img src="<%= post.user.dp ? post.user.dp : 'https://via.placeholder.com/50' %>"
                  class="rounded-circle border" width="50" height="50" style="object-fit: cover;">
              </a>

              <div>
                <a href="/user/<%= post.user._id %>" class="text-decoration-none text-dark">
                  <div class="fw-bold">
                    <%= post.user.fullname %>
                  </div>
                </a>

                <a href="/user/<%= post.user._id %>" class="text-decoration-none text-dark">
                  <div class="text-muted">
                    @<%= post.user.username %>
                  </div>
                </a>
              </div>

            </div>

            <hr>

            <div class="d-flex align-items-center gap-2">

              <form action="/like/<%= post._id %>" method="POST">

                <button type="submit" class="btn <%= liked ? 'btn-danger' : 'btn-outline-danger' %>">

                  <%= liked ? "❤️ Liked" : "🤍 Like" %>

                </button>

              </form>

              <form action="/save/<%= post._id %>" method="POST">

                <button type="submit" class="btn <%= saved ? 'btn-warning' : 'btn-outline-secondary' %>">

                  <%= saved ? '⭐ Saved' : '☆  Save' %>

                </button>

              </form>

            </div>

            <p class="text-muted mt-2 mb-0">
              ❤️ <%= likeCount %> likes
            </p>

          </div>

        </div>

      </div>

    </div>

  </div>

</body>

</html>