<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - Printrest</title>

  <style>
    .post-card {
      cursor: pointer;
      box-shadow: 8px 8px 4px gray;
    }

    .post-card:hover {
      transform: scale(1.03);
      transition: 0.3s ease;
    }

    .feed-link:hover {
      opacity: 0.8;
    }

    .profile-pic {
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .profile-pic:hover {
      transform: scale(1.1);
    }
  </style>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <!-- NAVBAR -->
  <nav class="navbar navbar-light bg-white shadow-sm px-4">

    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Pinterest-logo.png" width="30" height="30">

      <span class="fw-bold text-danger">Printrest</span>
    </a>

    <!-- Feed + Search -->
    <div class="d-flex align-items-center gap-3 flex-grow-1 mx-4">

      <a href="/" class="text-danger fw-bold text-decoration-none">
        Feed
      </a>

      <form action="/search" method="GET" class="flex-grow-1">
        <input type="text" name="query" class="form-control rounded-pill" placeholder="Search for ideas...">
      </form>

    </div>

    <!-- Right Side -->
    <div class="d-flex align-items-center gap-3">

      <!-- Profile Link -->
      <a href="/profile" class="text-dark fw-bold text-decoration-none profile-pic">
      </a>

      <!-- DP -->
      <a href="/profile">
        <img src="/images/uploads/<%= user.dp %>" class="profile-pic rounded-circle border" width="40" height="40"
          style="object-fit: cover;">
      </a>

      <!-- Logout -->
      <a href="/logout" class="btn btn-outline-danger btn-sm">
        Logout
      </a>

    </div>

  </nav>

  <div class="container mt-4">

    <!-- USER INFO + DP + UPLOAD + POST FORM IN ONE LINE -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">

        <div class="d-flex flex-wrap align-items-center gap-4">

          <!-- DP -->
          <div class="text-center">
            <img src="/images/uploads/<%= user.dp %>" class="rounded-circle border" width="100" height="100"
              style="object-fit: cover;">

            <!-- UPLOAD DP -->
            <form action="/upload-dp" method="POST" enctype="multipart/form-data" class="mt-2">
              <input type="file" name="dp" class="form-control form-control-sm mb-1" required>
              <button class="btn btn-danger btn-sm w-100">
                Update DP
              </button>
            </form>
          </div>

          <!-- USER INFO -->
          <div class="flex-grow-1">
            <h4 class="fw-bold mb-1">
              Welcome Back
              <%= user.fullname %> 👋
            </h4>

            <p class="text-muted mb-1">
              <b>Username:</b>
              <%= user.username %>
            </p>

            <p class="text-muted mb-0">
              <b>Email:</b>
              <%= user.email %>
            </p>

            <a href="/saved-posts" class="btn btn-warning btn-sm mt-2">
              ⭐ Saved Posts
            </a>
          </div>

          <!-- CREATE POST -->
          <div style="min-width: 300px;">
            <h4 class="fw-bold mb-1">
              Create Posts
            </h4>
            <form action="/createpost" method="POST" enctype="multipart/form-data">

              <input type="text" name="title" placeholder="Title" class="form-control form-control-sm mb-2" required>

              <input type="text" name="description" placeholder="Description" class="form-control form-control-sm mb-2">

              <input type="file" name="image" class="form-control form-control-sm mb-2" required>

              <button class="btn btn-danger btn-sm w-100">
                Create Post
              </button>

            </form>
          </div>

        </div>

      </div>
    </div>


    <!-- POSTS SECTION -->
    <!-- POSTS SECTION -->
    <h4 class="mb-3">Your Posts</h4>

    <% if (user.posts.length> 0) { %>

      <div class="row" data-masonry='{"percentPosition": true }'>

        <% user.posts.forEach(function(post) { %>

          <div class="col-md-4 mb-4">

            <div class="card post-card shadow-sm border-0">

              <!-- IMAGE -->
              <img src="/images/uploads/<%= post.image %>" class="card-img-top">

              <div class="card-body">

                <!-- TITLE + DESCRIPTION -->
                <h6 class="fw-bold mb-1">
                  <%= post.title %>
                </h6>

                <p class="text-muted small mb-2">
                  <%= post.description %>
                </p>

                <!-- LIKE + SAVE ROW -->
                <div class="d-flex align-items-center gap-2 mb-2">

                  <!-- LIKE BUTTON -->
                  <form action="/like/<%= post._id %>" method="POST" class="m-0">

                    <button class="btn btn-sm btn-outline-danger">
                      ❤️ Like
                    </button>

                  </form>

                  <!-- LIKE COUNT -->
                  <small class="text-muted">
                    <!-- <%= post.likes ? post.likes.length : 0 %> likes -->
                    <%= post.likeCount || 0 %> likes
                  </small>

                  <!-- SAVE BUTTON -->
                  <form action="/save/<%= post._id %>" method="POST" class="m-0 ms-auto">

                    <% let isSaved=user.savedPosts?.some(id=> id.toString() === post._id.toString()); %>

                      <% if(isSaved){ %>
                        <button class="btn btn-sm btn-warning">
                          ⭐ Saved
                        </button>
                        <% } else { %>
                          <button class="btn btn-sm btn-outline-warning">
                            ☆ Save
                          </button>
                          <% } %>

                  </form>

                  <!-- SAVE COUNT -->
                  <small class="text-muted ms-2">
                    <!-- <%= post.savedBy ? post.savedBy.length : 0 %> saves -->
                    <%= post.saveCount || 0 %> saves
                  </small>

                </div>

                <!-- DELETE -->
                <form action="/deletepost/<%= post._id %>" method="POST">
                  <button class="btn btn-sm btn-danger w-100">
                    Delete
                  </button>
                </form>

              </div>

            </div>

          </div>

          <% }) %>

      </div>

      <% } else { %>

        <div class="alert alert-secondary">
          No posts yet 😢
        </div>

        <% } %>
          <hr class="my-5">

  </div>

  <script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js"></script>
  <script>
    window.onload = function () {
      var grid = document.querySelector('.row');
      new Masonry(grid, {
        itemSelector: '.col-md-4',
        percentPosition: true
      });
    };
  </script>
</body>

</html>