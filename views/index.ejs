<!DOCTYPE html>
<html>

<head>
  <title>
    <%= title %>
  </title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .post-card {
      cursor: pointer;
      transition: 0.3s;
    }

    .post-card:hover {
      transform: scale(1.03);
    }

    .profile-pic {
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .profile-pic:hover {
      transform: scale(1.1);
    }
  </style>

</head>

<body class="bg-light">
  <nav class="navbar navbar-light bg-white shadow-sm px-4">

    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <img src="https://upload.wikimedia.org/wikipedia/commons/0/08/Pinterest-logo.png" width="30" height="30">

      <span class="fw-bold text-danger">Printrest</span>
    </a>

    <!-- Search Bar and feed -->
    <div class="d-flex align-items-center gap-3 flex-grow-1 mx-4">

      <a href="/" class="text-danger fw-bold text-decoration-none">
        Feed
      </a>

      <form action="/search" method="GET" class="flex-grow-1">
        <input type="text" name="query" class="form-control rounded-pill" placeholder="Search for ideas...">
      </form>

    </div>
    <!-- end  -->

    <!-- Buttons -->
    <% if(user){ %>

      <div class="d-flex align-items-center gap-3">

        <a href="/profile">

          <img src="<%= user.dp ? '/images/uploads/' + user.dp : 'https://via.placeholder.com/40' %>"
            class="profile-pic rounded-circle border" width="40" height="40" style="object-fit: cover">

        </a>

        <a href="/logout" class="btn btn-outline-danger btn-sm">
          Logout
        </a>

      </div>

      <% } else { %>

        <div class="d-flex gap-2">

          <a href="/login" class="btn btn-danger btn-sm">
            Login
          </a>

          <a href="/register" class="btn btn-outline-danger btn-sm">
            Signup
          </a>

        </div>

        <% } %>

  </nav>
  <!-- end of navbar-->

  <!-- Feed -->
  <div class="container mt-4">

    <div class="row">

      <% posts.forEach(function(post){ %>

        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">

          <a href="/post/<%= post._id %>" class="text-decoration-none text-dark">

            <div class="card border-0 shadow-sm post-card">

              <img src="/images/uploads/<%= post.image %>" class="card-img-top">

              <div class="card-body">

                <h6 class="fw-bold">
                  <%= post.title %>
                </h6>

                <p class="text-muted small">
                  <%= post.description %>
                </p>

                <!-- LIKE BUTTON -->
<form action="/like/<%= post._id %>" method="POST">

  <% if(user){ %>

    <% if(post.liked){ %>

     <button
  class="btn btn-sm btn-outline-danger like-btn"
  data-postid="<%= post._id %>"
>
  ❤️ Like
</button>
    <% } else { %>

      <button class="btn btn-sm btn-outline-secondary">
        🤍 Like
      </button>

    <% } %>

  <% } else { %>

    <a href="/login" class="btn btn-sm btn-outline-secondary">
      🤍 Like
    </a>

  <% } %>

  <small class="ms-2 text-muted">
    <%= post.likeCount || 0 %> likes
  </small>

</form>
<!-- end of like button -->

                <hr>

                <div class="d-flex align-items-center gap-2 mt-2">

                  <a href="/user/<%= post.user._id %>">
                    <img
                      src="<%= post.user.dp ? '/images/uploads/' + post.user.dp : 'https://via.placeholder.com/35' %>"
                      class="rounded-circle border" width="30" height="30" style="object-fit: cover;">
                  </a>

                  <div>
                    <small class="text-muted d-block">
                      Posted by
                    </small>

                    <a href="/user/<%= post.user._id %>" class="text-decoration-none text-dark fw-bold">
                      <%= post.user.username %>
                    </a>
                  </div>

                </div>

              </div>

            </div>

          </a>

        </div>

        <% }) %>

    </div>

  </div>
  <!-- End of feed -->

  <!-- Search Result -->
  <% if (typeof query !=='undefined' && posts) { %>

    <h2 class="my-4 text-center">
      Results for "<%= query %>"
    </h2>

    <div class="row">
      <% posts.forEach(function(post){ %>

        <div class="col-md-3 mb-3">
          <div class="card">

            <img src="/images/uploads/<%= post.image %>" class="card-img-top">

            <div class="card-body">
              <h6>
                <%= post.title %>
              </h6>
              <p>
                <%= post.description %>
              </p>
            </div>

          </div>
        </div>

        <% }) %>
    </div>

    <% } %>
      <!-- end of search result -->


      <!-- Scripts -->
      <script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js"></script>

      <script>
        window.onload = function () {
          const grid = document.querySelector('.row');

          if (grid) {
            new Masonry(grid, {
              itemSelector: '.col-lg-3',
              percentPosition: true
            });
          }
        }
      </script>
</body>

</html>